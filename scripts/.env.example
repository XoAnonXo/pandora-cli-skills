# Runtime variables for market launcher scripts
CHAIN_ID=1
RPC_URL=https://ethereum.publicnode.com

# Preferred key name for Pandora execution commands:
PANDORA_PRIVATE_KEY=0x...
# Backward-compatible legacy key name (still supported):
PRIVATE_KEY=0x...

ORACLE=0x259308E7d8557e4Ba192De1aB8Cf7e0E21896442
FACTORY=0xaB120F1FD31FB1EC39893B75d80a3822b1Cd8d0c
USDC=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Optional: mirror resolution defaults for guided onboarding or manual reuse.
# Explicit --sources still win; this fallback is only for env-driven setups.
PANDORA_RESOLUTION_SOURCES=https://www.espn.com/soccer/,https://www.bbc.com/sport/football

# Optional: Polymarket live hedging credentials for `pandora mirror sync --execute-live`
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYMARKET_PRIVATE_KEY=0x...
# Polymarket proxy wallet / Gnosis Safe address (NOT your EOA wallet address)
POLYMARKET_FUNDER=
# The next 3 values are only required for live (non-paper) hedge execution.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Optional: sportsbook / Odds API-style provider configuration for sports workflows.
# Fill the primary base URL with your provider endpoint and add an API key if needed.
SPORTSBOOK_PROVIDER_MODE=auto
SPORTSBOOK_PRIMARY_BASE_URL=
SPORTSBOOK_PRIMARY_API_KEY=
SPORTSBOOK_PRIMARY_API_KEY_MODE=header
SPORTSBOOK_PRIMARY_API_KEY_QUERY_PARAM=apiKey
SPORTSBOOK_BACKUP_BASE_URL=
SPORTSBOOK_BACKUP_API_KEY=
SPORTSBOOK_BACKUP_API_KEY_MODE=header
SPORTSBOOK_BACKUP_API_KEY_QUERY_PARAM=apiKey

# Optional: deployment host control-plane credentials for daemon or gateway rollout.
# DigitalOcean is one supported target, but any provider with an API can be represented here.
PANDORA_DAEMON_PROVIDER=
PANDORA_DAEMON_API_BASE_URL=
PANDORA_DAEMON_API_TOKEN=
