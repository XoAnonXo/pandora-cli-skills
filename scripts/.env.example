# Runtime variables for market launcher scripts
CHAIN_ID=1
RPC_URL=https://ethereum.publicnode.com
# Preferred key name for Pandora execution commands:
PANDORA_PRIVATE_KEY=0x...
# Backward-compatible legacy key name (still supported):
PRIVATE_KEY=0x...
ORACLE=0x259308E7d8557e4Ba192De1aB8Cf7e0E21896442
FACTORY=0xaB120F1FD31FB1EC39893B75d80a3822b1Cd8d0c
USDC=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Optional: Polymarket live hedging credentials for `pandora mirror sync --execute-live`
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYMARKET_PRIVATE_KEY=0x...
# Polymarket proxy wallet / Gnosis Safe address (NOT your EOA wallet address)
POLYMARKET_FUNDER=
# The next 3 values are only required for live (non-paper) hedge execution.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
